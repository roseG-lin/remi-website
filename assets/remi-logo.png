<svg width="512" height="512" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <!-- 暗金渐变 -->
    <linearGradient id="goldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#d4af37"/>
      <stop offset="50%" style="stop-color:#f4d03f"/>
      <stop offset="100%" style="stop-color:#c9a227"/>
    </linearGradient>
    
    <!-- 金属光泽 -->
    <linearGradient id="metallicGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#b8941f"/>
      <stop offset="30%" style="stop-color:#f4d03f"/>
      <stop offset="50%" style="stop-color:#d4af37"/>
      <stop offset="70%" style="stop-color:#f4d03f"/>
      <stop offset="100%" style="stop-color:#b8941f"/>
    </linearGradient>
    
    <!-- 发光效果 -->
    <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur stdDeviation="8" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- 背景 -->
  <rect width="512" height="512" fill="#0a0e1a"/>
  
  <!-- 外环光晕 -->
  <circle cx="256" cy="256" r="200" fill="url(#goldGrad)" opacity="0.05" filter="url(#glow)"/>
  <circle cx="256" cy="256" r="180" fill="none" stroke="url(#goldGrad)" stroke-width="1" opacity="0.2"/>
  <circle cx="256" cy="256" r="150" fill="none" stroke="url(#goldGrad)" stroke-width="1" opacity="0.15"/>
  
  <!-- R 字母主体 -->
  <g filter="url(#glow)" transform="translate(128, 128) scale(6)">
    <!-- 左侧竖线 -->
    <rect x="0" y="0" width="8" height="45" rx="4" fill="url(#metallicGrad)"/>
    
    <!-- 顶部弧线 -->
    <path d="M 8 3.5 L 32 3.5 A 15.5 15.5 0 0 1 32 34 L 8 34" stroke="url(#metallicGrad)" stroke-width="8" fill="none" stroke-linecap="round"/>
    
    <!-- 中间连接 -->
    <rect x="8" y="14" width="24" height="8" rx="4" fill="url(#metallicGrad)"/>
    
    <!-- 右下斜腿 -->
    <rect x="22" y="20" width="8" height="22" rx="4" fill="url(#metallicGrad)" transform="rotate(35 26 31)"/>
  </g>
  
  <!-- 装饰轨道 -->
  <ellipse cx="256" cy="256" rx="120" ry="50" fill="none" stroke="url(#goldGrad)" stroke-width="2" opacity="0.3" transform="rotate(-30 256 256)"/>
  <ellipse cx="256" cy="256" rx="120" ry="50" fill="none" stroke="url(#goldGrad)" stroke-width="2" opacity="0.3" transform="rotate(30 256 256)"/>
  
  <!-- 光点装饰 -->
  <circle cx="380" cy="132" r="6" fill="url(#goldGrad)" filter="url(#glow)"/>
  <circle cx="132" cy="380" r="4" fill="url(#goldGrad)" filter="url(#glow)"/>
  <circle cx="380" cy="380" r="5" fill="url(#goldGrad)" filter="url(#glow)"/>
  <circle cx="132" cy="132" r="3" fill="url(#goldGrad)" filter="url(#glow)"/>
</svg>
